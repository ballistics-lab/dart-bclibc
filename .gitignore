# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
build/
coverage/

# Native build artifacts — `dart run dart_bclibc:build_native` writes here
# (dart/lib/native/), and a local path-dependency build can also write
# straight into either package's own directory tree.
lib/native/
.cxx/
.gradle/
*.so
*.dylib
*.dll

# Wasm test fixture, copied from assets/wasm/ (the checked-in package
# asset) — see test/web/*_test.dart docstrings for the copy command.
test/web/assets/

# Scratch/experiment dirs (e.g. tmp/testd/ used to repro issues by hand).
/tmp/
